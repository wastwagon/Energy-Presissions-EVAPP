# Application Environment Variables
# Copy this file to .env and update with your values

# Application
NODE_ENV=development
PORT=3000
OCPP_WEBSOCKET_PORT=9000

# Database
DATABASE_URL=postgresql://evbilling:evbilling_password@localhost:5432/ev_billing_db

# Customers created via register / Apple / Google when the client does not send vendorId (single-tenant default is 1)
DEFAULT_CUSTOMER_VENDOR_ID=1

# Bootstrap SuperAdmin + vendor admins + walk-in when missing (runs in production; opt out with false)
SEED_BOOTSTRAP_USERS=true
# Demo-only customer accounts (customer@…): non-production unless ENABLE_DEV_SEED=true
ENABLE_DEV_SEED=false
DB_HOST=postgres
DB_PORT=5432
DB_USER=evbilling
DB_PASSWORD=evbilling_password
DB_NAME=ev_billing_db

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=redis
REDIS_PORT=6379

# Google OAuth (for Login with Google)
GOOGLE_CLIENT_ID=14712678053-uff0du4nbptiqehpksue1vem63ptda6t.apps.googleusercontent.com

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production
JWT_REFRESH_EXPIRES_IN=30d

# Payment Gateway - Stripe (optional / legacy)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Payment Gateway - Paystack (Ghana — required for wallet / card / mobile money)
# Get keys from https://dashboard.paystack.com/#/settings/developer
# Never commit real keys; copy this file to .env and set values locally or in your host (Render, etc.).
PAYSTACK_SECRET_KEY=sk_live_your_secret_key
PAYSTACK_PUBLIC_KEY=pk_live_your_public_key
# URL Paystack redirects to after payment (use your production app URL; local example below)
PAYSTACK_CALLBACK_URL=http://localhost:3001/user/wallet/top-up

# Email Service
SENDGRID_API_KEY=your_sendgrid_api_key
EMAIL_FROM=noreply@yourevcharging.com

# CORS (browser: frontend + WebView; comma-separated. Code reads CORS_ORIGINS and CORS_ORIGIN.)
# FRONTEND_URL is also merged into the allowlist.
# Set CORS_STRICT_ORIGINS=true to allow only the explicit list (no https://*.energyprecisions.com wildcard).
CORS_ORIGINS=http://localhost:3001,http://localhost:5173
FRONTEND_URL=http://localhost:3001

# Object storage (S3-compatible: MinIO locally, AWS S3 / R2 in production)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ev-billing
# Public URL prefix for browser <img src>; required for most CDNs / virtual-hosted S3
# Example: https://cdn.example.com/my-bucket  or  https://s3.eu-west-1.amazonaws.com/my-bucket
MINIO_PUBLIC_BASE_URL=
