# API (Vite) — if unset, the app uses /api on the same host (good: no CORS; needs reverse proxy to Nest).
# If you set a full URL to a different host (e.g. https://api.example.com/api), the API must allow
# the website origin in CORS, or you will see "Cannot reach" / network errors in the browser.
# VITE_API_URL=
# VITE_API_URL=/api
# VITE_API_URL=https://api.cleanmotion.energyprecisions.com/api
# Production Docker (Dockerfile.prod): set runtime API_ORIGIN (scheme+host) on the container so
# nginx can proxy /api and /ws to the API; omit VITE_WS_URL so the client uses same origin + /ws.
# VITE_WS_URL=ws://localhost/ocpp

# Google OAuth (for Login with Google)
VITE_GOOGLE_CLIENT_ID=14712678053-uff0du4nbptiqehpksue1vem63ptda6t.apps.googleusercontent.com

# Optional: canonical legal URLs for App Store / Play / Sign in with Apple (https only). If unset, dev uses in-app /privacy and /terms.
# Production (cleanmotion.energyprecisions.com) — set these on Render or copy into .env for a prod-like local build:
# VITE_PRIVACY_POLICY_URL=https://cleanmotion.energyprecisions.com/privacy
# VITE_TERMS_OF_SERVICE_URL=https://cleanmotion.energyprecisions.com/terms
# VITE_SUPPORT_URL=https://cleanmotion.energyprecisions.com/support
